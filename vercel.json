{
  "version": 2,
  "installCommand": "npm install --include=dev",
  "buildCommand": "prisma generate && tsc",
  "outputDirectory": ".",
  "env": {
    "DATABASE_URL": "file:/tmp/dev.db",
    "JWT_SECRET": "finance-dashboard-secret-2026"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}
